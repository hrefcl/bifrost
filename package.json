{
  "name": "webmail6",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "test:unit": "pnpm -r --parallel test:unit",
    "test:e2e": "pnpm -r test:e2e",
    "test:coverage": "pnpm -r --parallel test:coverage",
    "typecheck": "pnpm -r typecheck",
    "demo": "pnpm --filter @webmail6/api demo"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "eslint": "^9.17.0",
    "@eslint/js": "^9.17.0",
    "typescript-eslint": "^8.18.0",
    "prettier": "^3.4.0",
    "globals": "^15.14.0",
    "simple-git-hooks": "^2.11.1",
    "lint-staged": "^15.3.0",
    "eslint-plugin-vue": "^9.32.0",
    "eslint-config-prettier": "^9.1.0",
    "@vitest/coverage-v8": "^2.1.8"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*.{ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,cjs,mjs,json,md,yml,yaml,css,html}": [
      "prettier --write"
    ]
  }
}
