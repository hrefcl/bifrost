# FontAwesome Pro (iconos duotone). El token NO se commitea: se interpola desde el env
# FONTAWESOME_NPM_AUTH_TOKEN (secret de GitHub Actions en CI / export local en dev).
# Ver README §FontAwesome. Sin el env, sólo falla la instalación de @fortawesome/* (resto intacto).
@fortawesome:registry=https://npm.fontawesome.com/
//npm.fontawesome.com/:_authToken=${FONTAWESOME_NPM_AUTH_TOKEN}
