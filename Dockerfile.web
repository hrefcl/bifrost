FROM node:22-alpine AS builder
RUN corepack enable && corepack prepare pnpm@9.15.0 --activate
WORKDIR /app

# pnpm-lock.yaml es OBLIGATORIO para --frozen-lockfile (antes faltaba → fallaba el build).
# .npmrc apunta @fortawesome/* al registry Pro e interpola el token desde el env (no se hornea).
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml .npmrc ./
COPY packages/shared/package.json packages/shared/
COPY packages/web/package.json packages/web/
# BuildKit secret: el token FA Pro se lee sólo durante este RUN (no queda en ninguna capa/imagen).
# En CI lo inyecta docker.yml (secrets: fontawesome_token=${{ secrets.FONTAWESOME_NPM_AUTH_TOKEN }}).
RUN --mount=type=secret,id=fontawesome_token \
    FONTAWESOME_NPM_AUTH_TOKEN="$(cat /run/secrets/fontawesome_token 2>/dev/null || true)" \
    pnpm install --frozen-lockfile

COPY tsconfig.base.json ./
COPY packages/shared/src packages/shared/src
COPY packages/shared/tsconfig.json packages/shared/
COPY packages/web/index.html packages/web/vite.config.ts packages/web/tsconfig.json packages/web/tailwind.config.js packages/web/postcss.config.js packages/web/
COPY packages/web/src packages/web/src

RUN pnpm --filter @webmail6/shared build

# Metadata de build → la lee vite.config.ts y la bakea en el bundle (admin muestra qué versión corre).
ARG BUILD_NUMBER=dev
ARG BUILD_SHA=local
ARG BUILD_TIME=
ENV BUILD_NUMBER=$BUILD_NUMBER BUILD_SHA=$BUILD_SHA BUILD_TIME=$BUILD_TIME
RUN pnpm --filter @webmail6/web build

FROM nginx:1.27-alpine
COPY --from=builder /app/packages/web/dist /usr/share/nginx/html
# nginx.conf como TEMPLATE: el entrypoint de la imagen oficial corre envsubst sobre /etc/nginx/templates/*
# → /etc/nginx/conf.d/. `MEET_CSP_CONNECT` (vacío por default) se inyecta en el connect-src de la CSP en
# deploy-time cuando Meet está activo (review F3.4): Meet OFF ⇒ var vacía ⇒ CSP byte-idéntica a hoy.
# `NGINX_ENVSUBST_FILTER` limita la sustitución a esa sola var → las `$uri`/`$host` de nginx quedan intactas.
COPY nginx.conf /etc/nginx/templates/default.conf.template
ENV MEET_CSP_CONNECT="" \
    NGINX_ENVSUBST_FILTER="MEET_CSP_CONNECT"
EXPOSE 80
